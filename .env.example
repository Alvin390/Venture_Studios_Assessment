# Copy this file to .env and fill in every value before running docker-compose.
# See ENV_SETUP.md for step-by-step instructions on where to find each value.

# ---- Django ----------------------------------------------------------------
SECRET_KEY=your-secret-key-50-plus-chars-generate-below
DEBUG=False

# ---- Supabase (Project Settings > API) ------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- Supabase Database (Settings > Database > Connection pooling) ---------
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-database-password
DB_HOST=aws-0-xx-xxxx-1.pooler.supabase.com
DB_PORT=6543

# ---- Google Gemini (aistudio.google.com > Get API Key) --------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ---- Frontend build-time vars (same values as above, VITE_ prefix) --------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
